@prefix t3d: <https://anupta.github.io/terracotta3d#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

#################################################################
# Ontology Definition
#################################################################

<https://anupta.github.io/terracotta3d> a owl:Ontology ;
    rdfs:label "Terracotta3D Metadata Vocabulary" ;
    rdfs:comment "Custom metadata schema for 3D terracotta cultural objects (Bishnupur, West Bengal)" .

#################################################################
# 3D-SPECIFIC FIELDS (CORE CONTRIBUTION)
#################################################################

t3d:modelType a rdf:Property ;
    rdfs:label "Model Type" ;
    rdfs:comment "Type of 3D object such as sculpture, plaque, figurine, architectural element" .

t3d:polygonCount a rdf:Property ;
    rdfs:label "Polygon Count" ;
    rdfs:comment "Total number of polygons in the 3D model" .

t3d:textureResolution a rdf:Property ;
    rdfs:label "Texture Resolution" ;
    rdfs:comment "Resolution of textures applied to the 3D model (e.g., 4096x4096)" .

#################################################################
# CULTURAL / DOMAIN-SPECIFIC FIELDS (FROM TERRACOTTA STUDY)
#################################################################

t3d:deity a rdf:Property ;
    rdfs:label "Deity" ;
    rdfs:comment "Associated deity of the temple or terracotta object" .

t3d:technique a rdf:Property ;
    rdfs:label "Technique" ;
    rdfs:comment "Production technique such as moulded, carved brick, bas-relief" .

t3d:architecturalType a rdf:Property ;
    rdfs:label "Architectural Type" ;
    rdfs:comment "Architectural classification such as chala, ratna, rekha" .

t3d:religiousContext a rdf:Property ;
    rdfs:label "Religious Context" ;
    rdfs:comment "Religious significance or usage context" .

t3d:iconography a rdf:Property ;
    rdfs:label "Iconography / Theme" ;
    rdfs:comment "Narrative or visual theme such as Ramayana, Krishna Leela" .

t3d:heritageStatus a rdf:Property ;
    rdfs:label "Heritage Status" ;
    rdfs:comment "Official heritage designation (ASI, State Protected, etc.)" .

#################################################################
# OPTIONAL DOMAIN ENRICHMENT (USEFUL BUT NOT DUPLICATE)
#################################################################

t3d:stylePeriod a rdf:Property ;
    rdfs:label "Style Period" ;
    rdfs:comment "Historical or stylistic period (e.g., Malla dynasty)" .

t3d:colour a rdf:Property ;
    rdfs:label "Colour" ;
    rdfs:comment "Dominant colour or visual tone of terracotta" .

t3d:note a rdf:Property ;
    rdfs:label "Note" ;
    rdfs:comment "Additional descriptive or interpretative notes" .
