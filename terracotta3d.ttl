@prefix t3d: <https://anupta.github.io/terracotta3d#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

#################################################################
# Ontology Definition
#################################################################

<https://anupta.github.io/terracotta3d> a owl:Ontology ;
    rdfs:label "Terracotta3D Metadata Vocabulary" ;
    rdfs:comment "Custom metadata schema for 3D terracotta cultural objects (Bishnupur, West Bengal)" .

#################################################################
# CULTURAL / INTERPRETATIVE CONTEXT
#################################################################

t3d:deity a rdf:Property ;
    rdfs:label "Deity" ;
    rdfs:comment "Associated deity of the temple or represented in the terracotta object" .

t3d:religiousContext a rdf:Property ;
    rdfs:label "Religious Context" ;
    rdfs:comment "Religious tradition, usage, or cultural significance associated with the object" .

t3d:iconography a rdf:Property ;
    rdfs:label "Iconography / Theme" ;
    rdfs:comment "Narrative or symbolic theme depicted (e.g., Ramayana scenes, Krishna Leela)" .

#################################################################
# ARCHITECTURAL INFORMATION
#################################################################

t3d:architecturalPlan a rdf:Property ;
    rdfs:label "Architectural Plan" ;
    rdfs:comment "Ground plan or layout of the structure (e.g., square, rectangular, cruciform, ek-ratna base)" .

#################################################################
# CONDITION / CONSERVATION / LEGAL
#################################################################

t3d:architecturalType a rdf:Property ;
    rdfs:label "Conservation Status" ;
    rdfs:comment "Current conservation condition (e.g., conserved, under restoration, neglected, stabilized)" .

t3d:heritageStatus a rdf:Property ;
    rdfs:label "Structural Integrity" ;
    rdfs:comment "Physical condition of the structure (e.g., intact, minor damage, major damage, fragmentary, restored)" .

t3d:legalStatus a rdf:Property ;
    rdfs:label "Legal Status" ;
    rdfs:comment "Legal protection or ownership status (e.g., ASI Protected Monument, State Protected, Unprotected, Privately Owned)" .

#################################################################
# 3D CREATION / DIGITAL WORKFLOW
#################################################################

t3d:technique a rdf:Property ;
    rdfs:label "Processing Application" ;
    rdfs:comment "Software or application used in processing the 3D model (e.g., Agisoft Metashape, Blender)" .

t3d:stylePeriod a rdf:Property ;
    rdfs:label "3D Digitization Method" ;
    rdfs:comment "Method used to create the 3D model (e.g., photogrammetry, laser scanning, structured light scanning, manual modeling, hybrid method)" .

t3d:note a rdf:Property ;
    rdfs:label "Accuracy Level" ;
    rdfs:comment "Estimated accuracy or fidelity of the 3D model (e.g., high, medium, low, survey-grade)" .
